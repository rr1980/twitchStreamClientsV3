{
  "name": "twitch-stream-clients-v3",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --coverage",
    "coverage:check": "node ./scripts/check-coverage.mjs",
    "test:coverage:ci": "npm run test:coverage && npm run coverage:check",
    "lint": "ng lint",
    "http": "http-server --port 8086 -c-1 ./dist/twitchStreamClientsV3/browser"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^21.2.6",
    "@angular/compiler": "^21.2.6",
    "@angular/core": "^21.2.6",
    "@angular/forms": "^21.2.6",
    "@angular/platform-browser": "^21.2.6",
    "@angular/router": "^21.2.6",
    "@angular/service-worker": "^21.2.6",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.6",
    "@eslint/js": "^10.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "21.3.1",
    "eslint": "^10.1.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "^4.1.2"
  }
}
